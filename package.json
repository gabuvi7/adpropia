{
  "name": "adpropia",
  "version": "0.1.0",
  "private": true,
  "description": "AdPropIA — SaaS multi-tenant real estate management platform.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @adpropia/api --filter @adpropia/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "mutation:api": "pnpm --filter @adpropia/api mutation",
    "db:generate": "pnpm --filter @adpropia/database prisma:generate",
    "db:migrate": "pnpm --filter @adpropia/database prisma:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
