# Copy to .env.local or service-specific env files. Never commit real secrets.

# Shared PostgreSQL database for local development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gu_prop?schema=public"

# API
API_PORT=3001
# Auth0 JWT configuration (production). Set these for JWT-based auth.
# AUTH0_ISSUER="https://<your-tenant>.auth0.com/"
# AUTH0_AUDIENCE="<your-api-identifier>"
# Deprecated: local JWT settings (temp header fallback in dev).
JWT_ISSUER="gu-prop-local"
JWT_AUDIENCE="gu-prop-web"

# Web
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
