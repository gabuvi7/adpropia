# Copy to .env.local or service-specific env files. Never commit real secrets.

# Shared PostgreSQL database for local development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adpropia?schema=public"

# API
API_PORT=3001
# Auth0 JWT configuration (production). Set these for JWT-based auth.
# AUTH0_ISSUER="https://<your-tenant>.auth0.com/"
# AUTH0_AUDIENCE="<your-api-identifier>"
# Deprecated: local JWT settings (temp header fallback in dev).
JWT_ISSUER="adpropia-local"
JWT_AUDIENCE="adpropia-web"

# Frontend Auth0 SDK (server-only, never expose NEXT_PUBLIC_* for auth secrets)
AUTH0_SECRET="<long-random-secret-at-least-32-chars>"
APP_BASE_URL="http://localhost:3000"
AUTH0_DOMAIN="dev-adpropia.us.auth0.com"
AUTH0_CLIENT_ID="<auth0-client-id>"
AUTH0_CLIENT_SECRET="<auth0-client-secret>"
AUTH0_AUDIENCE="https://api.adpropia.com.ar"
# Optional: set for fixed Auth0 organization-scoped web login during smoke validation.
AUTH0_ORGANIZATION_ID="org_xxx"
ADPROPIA_API_BASE_URL="http://localhost:3001"

# Public access request intake
TURNSTILE_SECRET_KEY="<cloudflare-turnstile-secret-key>"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="<cloudflare-turnstile-site-key>"
RESEND_API_KEY="<resend-api-key>"
ACCESS_REQUEST_EMAIL_TO="guviedo@adpropia.com.ar"
# Optional: override the verified Resend sender.
RESEND_FROM_EMAIL="AdPropIA <no-reply@adpropia.com.ar>"

# Web
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Document Storage — Cloudflare R2 (S3-compatible)
# Set STORAGE_PROVIDER=r2 to use R2; default/local fallback is local disk storage.
STORAGE_PROVIDER="local"
# R2_ACCOUNT_ID="example-account-id"
R2_ENDPOINT="https://example-endpoint.r2.cloudflarestorage.com"
R2_BUCKET_NAME="example-bucket-name"
R2_REGION="auto"
# R2_ACCESS_KEY_ID="example-access-key-id"     # Set credentials in .env.local (never commit)
# R2_SECRET_ACCESS_KEY="example-secret-access-key" # Set credentials in .env.local (never commit)

# Example for smoke:auth0
AUTH0_ORGANIZATION_ID="org_xxx" \
AUTH0_USER_ID="auth0|xxx" \
AUTH0_USER_EMAIL="agent@example.com" \
AUTH0_USER_NAME="Smoke Agent" \
TENANT_NAME="Smoke Agency" \
TENANT_SLUG="smoke-agency" \
TENANT_ROLE="ADMIN" \
pnpm smoke:auth0

