# Root .env is not the source of truth for this monorepo.
# Keep real local values in service-specific env files instead:
#
# - apps/web/.env.local from apps/web/.env.local.example
# - apps/api/.env from apps/api/.env.example
# - packages/database/.env from packages/database/.env.example
#
# Root .env may be used only as an optional local shell convenience for ad-hoc
# commands that are run from the repository root. Do not duplicate service
# secrets here unless the command explicitly needs them.
