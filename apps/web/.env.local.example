# Next.js local environment. Copy to apps/web/.env.local.

# Auth0 Web SDK server-only values. Do not prefix these with NEXT_PUBLIC_.
AUTH0_SECRET="<long-random-secret-at-least-32-chars>"
APP_BASE_URL="http://localhost:3000"
AUTH0_DOMAIN="<auth0-tenant-domain>"
AUTH0_CLIENT_ID="<auth0-client-id>"
AUTH0_CLIENT_SECRET="<auth0-client-secret>"
AUTH0_AUDIENCE="<auth0-api-audience-url>"
# Optional: fixed organization-scoped login during smoke validation.
# AUTH0_ORGANIZATION_ID="org_xxx"

# Web-to-API proxy target.
ADPROPIA_API_BASE_URL="http://localhost:3001"

# Browser-safe public values only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="<cloudflare-turnstile-site-key>"
