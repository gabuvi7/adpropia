# Nest API local environment. Copy to apps/api/.env.

# Local server.
API_PORT=3001

# API database access. Keep this aligned with packages/database/.env locally.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adpropia?schema=public"

# Auth0 JWT validation for protected API routes.
AUTH0_ISSUER="https://<your-tenant>.auth0.com/"
AUTH0_AUDIENCE="<your-api-identifier>"

# Public access request intake.
TURNSTILE_SECRET_KEY="<cloudflare-turnstile-secret-key>"
RESEND_API_KEY="<resend-api-key>"
ACCESS_REQUEST_EMAIL_TO="<recipient@example.com>"
# Optional: override the verified Resend sender.
# RESEND_FROM_EMAIL="AdPropIA <no-reply@example.com>"

# Document storage. Local disk is the default.
STORAGE_PROVIDER="local"
# STORAGE_BASE_PATH="./storage"

# Cloudflare R2, required only when STORAGE_PROVIDER="r2".
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# R2_BUCKET_NAME="<bucket-name>"
# R2_REGION="auto"
# R2_ACCESS_KEY_ID="<r2-access-key-id>"
# R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"

# Auth0 smoke bootstrap values. Use only outside production.
# AUTH0_ORGANIZATION_ID="org_xxx"
# AUTH0_USER_ID="auth0|xxx"
# AUTH0_USER_EMAIL="agent@example.com"
# AUTH0_USER_NAME="Smoke Agent"
# TENANT_NAME="Smoke Agency"
# TENANT_SLUG="smoke-agency"
# TENANT_ROLE="ADMIN"

# Error monitoring
# Leave blank or "null" locally/tests to disable Sentry event sending.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
